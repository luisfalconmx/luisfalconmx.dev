          headline="Mobile App"
          link="#"
          colorScheme="light"
          buttonText="View Project"
          image={ProjectCardImage}
          color="#E5F1FF"
          gridSpan={1}
        />
        <ProjectCard
          type="medium"
          title="Jewelry Website Redesign."
          headline="Web Site Design"
          link="#"
          image={ProjectCardImage}
          colorScheme="light"
          color="#5960ff"
          gridSpan={2}
        /> -->
      </div>
    </section>
  </main>
</Layout>
